                <mxCell id="3297" value="" style="group" parent="3295" vertex="1" connectable="0">
                    <mxGeometry x="44.5" y="23" width="151" height="49" as="geometry"/>
                </mxCell>
                <mxCell id="3298" value="&lt;p style=&quot;margin: 0px 0px 0px 13px; text-indent: -13px; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-stretch: normal; font-size: 14px; line-height: normal; color: rgb(14, 14, 14); text-align: start;&quot; class=&quot;p1&quot;&gt;&lt;br&gt;&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF77BF;strokeColor=none;arcSize=50;" parent="3297" vertex="1">
                    <mxGeometry y="9" width="151" height="33" as="geometry"/>
                </mxCell>
                <mxCell id="3299" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;i&gt;PostgreSQL&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;shadow=0;fontSize=23;fontStyle=1" parent="3297" vertex="1">
                    <mxGeometry x="31" width="89" height="49" as="geometry"/>
                </mxCell>
                <mxCell id="3306" value="Точка входа&lt;br&gt;Проверка авторизации&lt;br&gt;Распределение входящего сетевого трафика&lt;br&gt;между несколькими бекенд-сервисами" style="text;strokeColor=none;align=left;fillColor=#E6E6E6;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=1;strokeWidth=2;fontColor=#000000;perimeterSpacing=0;spacingLeft=6;perimeter=rectanglePerimeter;" parent="1" vertex="1">
                    <mxGeometry x="1873.89" y="953.5" width="277" height="77" as="geometry"/>
                </mxCell>
                <mxCell id="3309" value="Индентификация пользователя&lt;br&gt;Подтверждение личности пользователя&lt;br&gt;Выдача и валидация токена&lt;br&gt;Для подтверждения передачи данных будет использоваться JWT токен" style="text;strokeColor=none;align=left;fillColor=#E6E6E6;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=1;strokeWidth=2;fontColor=#000000;perimeterSpacing=0;spacingLeft=6;perimeter=rectanglePerimeter;" vertex="1" parent="1">
                    <mxGeometry x="2667" y="1030.5" width="323" height="77" as="geometry"/>
                </mxCell>
                <mxCell id="3325" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#000000;strokeWidth=2;entryX=0.236;entryY=0.018;entryDx=0;entryDy=0;entryPerimeter=0;exitX=0.573;exitY=0.983;exitDx=0;exitDy=0;exitPerimeter=0;" edge="1" parent="1" source="3323">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1695.500000000001" y="3092.999999999998" as="sourcePoint"/>
                        <mxPoint x="1694.4400000000005" y="3920.1460000000006" as="targetPoint"/>
                        <Array as="points">
                            <mxPoint x="1693" y="3507"/>
                            <mxPoint x="1694" y="3507"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="3326" value="Заявка на создание аукциона" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];rounded=1;labelBackgroundColor=#FFFFFF;fontColor=#000000;spacingTop=0;spacingLeft=0;spacing=2;" vertex="1" connectable="0" parent="1">
                    <mxGeometry x="1788.998488036479" y="3140.0014071002074" as="geometry"/>
                </mxCell>
                <mxCell id="3327" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;[Пользователь.ID]&lt;br&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;labelBackgroundColor=none;fontColor=#007575;" vertex="1" parent="1">
                    <mxGeometry x="1709" y="3144" width="160" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="3328" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;[Аукцион.Параметры]&lt;br&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;labelBackgroundColor=none;fontColor=#007575;" vertex="1" parent="1">
                    <mxGeometry x="1709" y="3158" width="160" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="1878" value="Сервис по обработке заказов пользователя&lt;br&gt;1) Пользователь подтверждает заказ из корзины&amp;nbsp;&lt;br&gt;2) Публикуется событие о новом заказе&lt;br&gt;3) Заказ проходит модерацию&lt;br&gt;4) Заказ размещается на аукционе и доступен дугим пользователям&lt;br&gt;5) Доступен подробный просмотр заказа - карточка товара или услуги" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;strokeWidth=2;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="3920" y="2375" width="520" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="3336" value="Сервис по обработке входящих сообщений и публикация события всем подписчикам" style="text;strokeColor=none;align=left;fillColor=#E6E6E6;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=1;strokeWidth=2;fontColor=#000000;perimeterSpacing=0;spacingLeft=6;perimeter=rectanglePerimeter;" vertex="1" parent="1">
                    <mxGeometry x="901" y="3980" width="369" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="3341" value="&lt;b style=&quot;font-size: 20px;&quot;&gt;Вход в приложение&lt;/b&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: initial; font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;1. Регистрация&lt;/u&gt;&lt;/span&gt;&lt;br style=&quot;background-color: initial; font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: initial; font-size: 20px;&quot;&gt;Пользователь (клиент) регистрируется в приложении - передает логин/пароль&lt;/span&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: initial; font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;2. Авторизация&lt;/u&gt;&lt;/span&gt;&lt;br style=&quot;background-color: initial; font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: initial; font-size: 20px;&quot;&gt;Пользователь (любой) вводит логин/пароль и получает JWT токен&lt;/span&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;font-size: 20px;&quot;&gt;Пользователь (клиент)&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;11. CRUD операция с профилем пользователя&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;При регистрации пользователь заполняет информацию о себе и далее может ее отпредактировать.&lt;br style=&quot;font-size: 20px;&quot;&gt;Возможнотсь удалить аккаунт&lt;br style=&quot;font-size: 20px;&quot;&gt;(на момент удаления необходимо проверить наличие активных созданных аукционов)&amp;nbsp;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;12. Обращение в тех поддержку&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;При подаче обращения указывается категория запроса, для более эффективной маршрутизации заявки нужному специалисту&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;font-size: 20px;&quot;&gt;Продавец&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;21. Добавление товара/услуги&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Пользователь заполняет форму товара/услуги, прикрепляет фото и добавляет его/ее к себе в профиль&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;22. Добавление скидки на товар/услугу&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Для привлечения покупателей, продавец может назначать скидочные предложение&lt;br style=&quot;font-size: 20px;&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;(Необходимо заполнить период действия акции)&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;23. Добавление аукциона&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Продавец создает аукцион и выставляет товары/услуги на продажу&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;23.1 Заявка на создание аукциона&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&amp;nbsp;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;После заполнения всех необходимых параметров, создается заявка на создание аукциона.&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Алгоритм назначает свободного администратора для валадции заявки и отправляет ему пуш уведомление.&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;После проверки заявки, продавец получает пуш уведомление о статусе&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;24. Обновление ставок аукциона&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Продавец может регулировать параметры аукциона&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;25. Создание апелляции по аукциону&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Продавец может подать апелляцию. Решение по апелляции принимает администратор.&amp;nbsp;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Пользователь получает нотификацию о ходе изменения статуса апелляции&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;26. Просмотр аналитики&lt;/u&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;font-size: 20px;&quot;&gt;Покупатель&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;31. Поиск товаров и услуг&lt;/u&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Пользователь может искать по названию, фильтровать по стоимости и дате публикации. &lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;Также возможно сравнить товары для выбора наиболее выгодного&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&#9;&lt;/span&gt;32. Добавление/редактирование товаров и услуг в корзине&lt;/u&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;еще не оформленные товары помещаются в отлельный сервис корзины&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;&#9;33. Оформление заказа&lt;/u&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;После формирования корзины пользователь оформляет выбранные товары/услуги&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;font-size: 20px;&quot;&gt;Оплата Заказа&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;41.&lt;/u&gt;&lt;/span&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: initial; text-indent: -21px; font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;Инициировать платёж&lt;/u&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: initial; text-indent: -21px; font-size: 20px;&quot;&gt;Торговая площадка инициирует платёж, отправив необходимые данные (ID пользователя, ID заказа, сумма заказа) в платёжный сервис.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: initial; text-indent: -21px; font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 20px;&quot;&gt;&lt;h1 style=&quot;margin-top: 0px; font-size: 20px;&quot;&gt;&lt;p style=&quot;margin: 0px 0px 0px 21px; text-indent: -21px; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-stretch: normal; line-height: normal; font-size: 20px;&quot; class=&quot;p1&quot;&gt;&lt;span style=&quot;font-weight: normal; font-size: 20px;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;u style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-stretch: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 20px;&quot; class=&quot;s1&quot;&gt;42.&amp;nbsp;&lt;/span&gt;Предоставить статус платежа&lt;/u&gt;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 21px; text-indent: -21px; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-stretch: normal; line-height: normal; font-size: 20px;&quot; class=&quot;p1&quot;&gt;&lt;span style=&quot;font-weight: normal; font-size: 20px;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;font face=&quot;YS Text, -apple-system, system-ui, Arial, Helvetica, sans-serif&quot; style=&quot;font-size: 20px;&quot;&gt;П&lt;/font&gt;латёжный сервис принял запрос на проведение оплаты,&lt;span style=&quot;font-size: 20px;&quot; class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;подтвердил возможность проведения платежа со счёта клиента, назначил идентификатор для этой транзакции и установил статус.&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 21px; text-indent: -21px; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-stretch: normal; line-height: normal; font-size: 20px;&quot; class=&quot;p1&quot;&gt;&lt;span style=&quot;font-weight: normal; font-size: 20px;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 21px; text-indent: -21px; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-kerning: auto; font-